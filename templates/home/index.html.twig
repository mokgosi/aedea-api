{# templates/home/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Welcome{% endblock %}

{% block body %}
<div class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-indigo-950">

    <div class="absolute inset-0 opacity-20">
        <div class="absolute left-0 top-0 h-96 w-96 rounded-full bg-indigo-500 blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-cyan-500 blur-3xl"></div>
    </div>

    <div class="relative flex min-h-screen items-center px-6 py-16">

        <div class="mx-auto max-w-7xl">

            <div class="grid items-center gap-16 lg:grid-cols-2">

                <div>

                    <div class="inline-flex items-center rounded-full border border-indigo-500/20 bg-indigo-500/10 px-4 py-1 text-sm font-medium text-indigo-300">
                        Welcome to Our Platform
                    </div>

                    <h1 class="mt-8 text-5xl font-extrabold leading-tight tracking-tight text-white sm:text-6xl">
                        Share Your Ideas.
                        <span class="bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">
                            Build Something Amazing.
                        </span>
                    </h1>

                    <p class="mt-8 max-w-2xl text-lg leading-8 text-slate-300">
                        Have a project idea, business proposal, or collaboration opportunity?
                        We'd love to hear from you.
                        Send us an email or use the contact form to share your vision.
                    </p>

                    <div class="mt-10 flex flex-col gap-4 sm:flex-row">

                        <a
                            href="{{ path('app_contact_new') }}"
                            class="inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-8 py-4 text-sm font-semibold text-white shadow-2xl transition hover:bg-indigo-700 hover:shadow-indigo-500/30"
                        >
                            Contact Us
                        </a>

                    </div>

                </div>

                <div class="relative">

                    <div class="rounded-3xl border border-white/10 bg-white/5 p-10 shadow-2xl backdrop-blur-xl">

                        <div class="flex items-center justify-between border-b border-white/10 pb-6">

                            <div>
                                <h2 class="text-2xl font-bold text-white">
                                    Admin Portal
                                </h2>

                                <p class="mt-2 text-slate-400">
                                    Secure access for administrators.
                                </p>
                            </div>

                            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-500/20">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c1.657 0 3-1.343 3-3S13.657 5 12 5 9 6.343 9 8s1.343 3 3 3zm0 2c-2.761 0-5 2.239-5 5h10c0-2.761-2.239-5-5-5z" />
                                </svg>
                            </div>

                        </div>

                        <div class="mt-8">

                            <p class="leading-7 text-slate-300">
                                Administrators can securely log in to manage contact requests,
                                monitor submissions, and respond to client inquiries.
                            </p>

                            <div class="mt-8">

                                <a
                                    href="{{ path('app_login') }}"
                                    class="inline-flex w-full items-center justify-center rounded-2xl bg-white px-6 py-4 text-sm font-semibold text-slate-900 shadow-lg transition hover:bg-slate-100"
                                >
                                    Admin Login
                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
{% endblock %}