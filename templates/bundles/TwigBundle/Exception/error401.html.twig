{% extends 'base.html.twig' %}

{% block title %}Authentication Required{% endblock %}

{% block body %}
<div class="flex min-h-screen items-center justify-center bg-gradient-to-br from-slate-950 via-slate-900 to-indigo-950 px-6 py-12">

    <div class="w-full max-w-2xl rounded-3xl border border-white/10 bg-white/10 p-10 text-center shadow-2xl backdrop-blur-xl">

        <span class="inline-flex rounded-full bg-amber-500/20 px-4 py-1 text-sm font-medium text-amber-300">
            401 Unauthorized
        </span>

        <h1 class="mt-6 text-5xl font-bold text-white">
            Authentication Required
        </h1>

        <p class="mt-4 text-lg leading-relaxed text-slate-300">
            You need to sign in to access this page.
        </p>

        <div class="mt-10 flex justify-center gap-4">
            <a
                href="{{ path('app_login') }}"
                class="rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-indigo-700"
            >
                Sign In
            </a>

            <a
                href="{{ path('homepage') }}"
                class="rounded-xl border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/20"
            >
                Homepage
            </a>
        </div>
    </div>
</div>
{% endblock %}