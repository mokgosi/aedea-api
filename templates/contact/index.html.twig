{# templates/contact/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Contacts{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 px-6 py-12">

    <div class="mx-auto max-w-7xl">

        <div class="mb-10 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
            <div>
                <h1 class="text-4xl font-bold tracking-tight text-white">
                    Contact Messages
                </h1>

                <p class="mt-2 text-slate-400">
                    Manage all customer contact submissions.
                </p>
            </div>

            <a
                href="{{ path('app_contact_new') }}"
                class="inline-flex items-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-indigo-700"
            >
                New Contact
            </a>
        </div>

        <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl backdrop-blur-xl">

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-white/10">

                    <thead class="bg-white/5">
                        <tr>
                            <th class="px-6 py-5 text-left text-xs font-semibold uppercase tracking-wider text-slate-300">
                                Name
                            </th>

                            <th class="px-6 py-5 text-left text-xs font-semibold uppercase tracking-wider text-slate-300">
                                Subject
                            </th>

                            <th class="px-6 py-5 text-left text-xs font-semibold uppercase tracking-wider text-slate-300">
                                Email
                            </th>

                            <th class="px-6 py-5 text-left text-xs font-semibold uppercase tracking-wider text-slate-300">
                                Created
                            </th>

                            <th class="px-6 py-5 text-right text-xs font-semibold uppercase tracking-wider text-slate-300">
                                Actions
                            </th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-white/5">

                        {% for contact in contacts %}
                            <tr class="transition hover:bg-white/5">

                                <td class="whitespace-nowrap px-6 py-5">
                                    <div class="font-semibold text-white">
                                        {{ contact.name }}
                                    </div>
                                </td>

                                <td class="px-6 py-5">
                                    <div class="max-w-xs truncate text-slate-300">
                                        {{ contact.subject }}
                                    </div>
                                </td>

                                <td class="px-6 py-5">
                                    <a
                                        href="mailto:{{ contact.email }}"
                                        class="text-indigo-400 transition hover:text-indigo-300"
                                    >
                                        {{ contact.email }}
                                    </a>
                                </td>

                                <td class="whitespace-nowrap px-6 py-5 text-slate-400">
                                    {{ contact.createdAt|date('d M Y, H:i') }}
                                </td>

                                <td class="whitespace-nowrap px-6 py-5 text-right">
                                    <div class="flex justify-end gap-3">

                                        <a
                                            href="{{ path('app_contact_show', {id: contact.id}) }}"
                                            class="rounded-lg bg-slate-800 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-700"
                                        >
                                            View
                                        </a>

                                        <a
                                            {# href="{{ path('contact_delete', {id: contact.id}) }}" #}
                                            class="rounded-lg bg-red-500/20 px-4 py-2 text-sm font-medium text-red-300 transition hover:bg-red-500/30"
                                        >
                                            Delete
                                        </a>

                                    </div>
                                </td>

                            </tr>

                        {% else %}
                            <tr>
                                <td colspan="5" class="px-6 py-16 text-center">

                                    <div class="mx-auto max-w-md">
                                        <div class="text-6xl">📭</div>

                                        <h3 class="mt-4 text-2xl font-semibold text-white">
                                            No Contacts Found
                                        </h3>

                                        <p class="mt-2 text-slate-400">
                                            Contact form submissions will appear here.
                                        </p>
                                    </div>

                                </td>
                            </tr>
                        {% endfor %}

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
