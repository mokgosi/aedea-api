{# templates/contact/show.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
    {{ contact.subject }}
{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 px-6 py-12">

    <div class="mx-auto max-w-5xl">

        <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">

            <div>
                <div class="mb-3 inline-flex rounded-full bg-indigo-500/10 px-4 py-1 text-sm font-medium text-indigo-300">
                    Contact Message
                </div>

                <h1 class="text-2xl font-bold tracking-tight text-white">
                    {{ contact.subject }}
                </h1>

                <p class="mt-3 text-slate-400">
                    Submitted on
                    {{ contact.createdAt|date('d M Y \\a\\t H:i') }}
                </p>
            </div>

            <div class="flex gap-3">

                <a
                    href="{{ path('app_contact_index') }}"
                    class="inline-flex items-center rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
                >
                    Back
                </a>

                <a
                    href="{{ path('app_contact_delete', {id: contact.id}) }}"
                    class="inline-flex items-center rounded-xl bg-red-500/20 px-5 py-3 text-sm font-semibold text-red-300 transition hover:bg-red-500/30"
                >
                    Delete
                </a>

            </div>
        </div>

        <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl backdrop-blur-xl">

            <div class="border-b border-white/10 px-8 py-6">

                <div class="grid gap-6 md:grid-cols-2">

                    <div>
                        <p class="text-sm font-medium uppercase tracking-wider text-slate-500">
                            Full Name
                        </p>

                        <p class="mt-2 text-lg font-semibold text-white">
                            {{ contact.name }}
                        </p>
                    </div>

                    <div>
                        <p class="text-sm font-medium uppercase tracking-wider text-slate-500">
                            Email Address
                        </p>

                        <a
                            href="mailto:{{ contact.email }}"
                            class="mt-2 inline-block text-lg font-semibold text-indigo-400 transition hover:text-indigo-300"
                        >
                            {{ contact.email }}
                        </a>
                    </div>

                </div>
            </div>

            <div class="px-8 py-8">

                <div class="mb-4">
                    <p class="text-sm font-medium uppercase tracking-wider text-slate-500">
                        Message
                    </p>
                </div>

                <div class="rounded-2xl border border-white/10 bg-slate-950/40 p-6">

                    <div class="prose prose-invert max-w-none text-slate-300 leading-8">
                        {{ contact.message|nl2br }}
                    </div>

                </div>

            </div>
        </div>

    </div>
</div>
{% endblock %}